# Configuration du modèle Ollama par défaut (OPTIONNEL)
# Utilisé seulement si "model" n'est pas spécifié dans la requête
# Les modèles sont téléchargés automatiquement à la première utilisation
DEFAULT_MODEL=llama3.2:3b

# Modèle de vision par défaut (OPTIONNEL - pour l'analyse d'images)
DEFAULT_VISION_MODEL=llama3.2-vision

# Patterns pour détecter les modèles de vision (séparés par des virgules)
# Les modèles contenant 'vision', '-vl' ou 'vl-' sont automatiquement détectés
VISION_MODELS_PATTERNS=llava,bakllava,llama3.2-vision,moondream,cogvlm,minicpm-v,qwen,qwen2-vl,qwen-vl,pixtral,internvl,molmo,video,vision

# Paramètres par défaut
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=512

# System prompt par défaut (OPTIONNEL)
# Utilisé pour définir le comportement du modèle
# DEFAULT_SYSTEM_PROMPT=You are a helpful assistant

# Host Ollama (ne pas modifier sauf besoin spécifique)
OLLAMA_HOST=http://localhost:11434

# Sécurité - Clé API pour l'authentification (optionnel)
# Si défini, toutes les requêtes doivent inclure cette clé dans le champ "api_key"
RUNPOD_API_KEY=your_secret_api_key_here

# URL de votre endpoint RunPod
# Format pour mode async: https://api.runpod.ai/v2/YOUR_ENDPOINT_ID/run
# Format pour mode sync:  https://api.runpod.ai/v2/YOUR_ENDPOINT_ID/runsync
RUNPOD_API_URL=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID/run